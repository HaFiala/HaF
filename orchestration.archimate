        <element xsi:type="archimate:DataObject" name="[table]dt_event_schedule" id="id-581aeeffc9774572b8cd5e38e6d5e5b5"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_feature_full" id="id-d9dc346e9a154541bb3066cd3f04de34"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_feature_invalid" id="id-a429e330afda45f1b28a4b7d438c1c74"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_filter_feature_full" id="id-96de28cc1bfe43f79902b7e21a0f9d35"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_filter_feature_history" id="id-1f7a29055a3c4e63b4a145a9f291c279"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_link_condition_link_full" id="id-a82401c2ce104eec995aaac3719ce9ec"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_link_condition_link_history" id="id-49e917168aed48168c0f647bb1331c08"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_node_condition_link_full" id="id-17a816110e1b48b5bd79e844c0591969"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_node_condition_link_history" id="id-26444f53849944ae8257c77b48ecc043"/>
        <element xsi:type="archimate:DataObject" name="[table]rt_event_schedule" id="id-a98a08e1516c45af9a78953f139e1d6e"/>
        <element xsi:type="archimate:DataObject" name="[table]rt_event_schedule_invalid" id="id-10a177844b884f42a0b2975aa383e21b"/>
        <element xsi:type="archimate:DataObject" name="[table]rt_event_stop_full" id="id-b96b2dea3c52434ba0d2992d5abe5bb9"/>
        <element xsi:type="archimate:DataObject" name="[table]rt_event_stop_invalid" id="id-63532b9b323745d5bb314901270eca0b"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_trigger_folder_def" id="id-aa0ea77e4102460bab19d3d3684e8303"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_event_full" id="id-02777cc7e45b49e68615929ea24ae6f9"/>
        <element xsi:type="archimate:DataObject" name="[table]dt_event_schedule_history" id="id-49a0eb47678345158b25c517c0720833"/>
        <element xsi:type="archimate:DataObject" name="[view] v_granular_resources" id="id-889db99bcc70406aa1ba736be8c26fe5">
          <documentation>-- new view to be deployed&#xD;
WITH filt AS (&#xD;
		SELECT distinct filter_key filterkey, filter_name, feature_value::integer&#xD;
		    from v_node_feature&#xD;
		    where feature_type_code::text = 'RESOURCE'::text&#xD;
)&#xD;
, resfil AS (&#xD;
         SELECT f.filterkey,&#xD;
            count(*) AS running&#xD;
           FROM filt f&#xD;
             JOIN ot_custom_filter_members ocfm ON f.filterkey = ocfm.filter_key&#xD;
             JOIN v_running_nodes vrn on vrn.dt_event_key = ocfm.dt_event_key&#xD;
          GROUP BY f.filterkey&#xD;
        )&#xD;
     SELECT f.filterkey, f.filter_name, &#xD;
        COALESCE(resfil.running, 0::bigint) AS resused,&#xD;
        COALESCE(cast(f.feature_value as int), 0::bigint) AS restotal,&#xD;
        COALESCE(f.feature_value - resfil.running, f.feature_value::bigint) AS resavailable&#xD;
       FROM filt f&#xD;
       LEFT JOIN resfil ON resfil.filterkey = f.filterkey</documentation>
        </element>
      </folder>
