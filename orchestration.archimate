    <element xsi:type="archimate:ApplicationService" name="Force start execution" id="id-4db43feb83fd452d896b3b8772fde0d7"/>
    <element xsi:type="archimate:ApplicationService" name="Start scheduled execution" id="id-d3fba37cfe114c2eb716879cbded7be0"/>
    <element xsi:type="archimate:ApplicationService" name="Start dependent execution" id="id-7a394b3004b24c8d9689b8401a30d2fb"/>
    <element xsi:type="archimate:ApplicationProcess" name="Check contraints for one candidate" id="id-01fd350f09ef408d8f6fad9d3fc537b3">
      <documentation>Description: Check technical conditions for candidate triggering and elimination of candidates for which technical conditions are not fulfilled&#xD;
&#xD;
Technically:&#xD;
˝˝0057˝˝&#xD;
&#xD;
&lt;for each {candidate}>&#xD;
&#xD;
1) {candidate.triggeringResult} = 'TO_BE_DETERMINED' and {candidate.node_type= 'BACKUP'} ˝˝0044c˝˝&#xD;
2) {candidate.triggeringResult} = 'TO_BE_DETERMINED' and {candidate.node_type= 'BACKUP'} ˝˝0044h˝˝&#xD;
3) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044f˝˝&#xD;
4) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044e˝˝&#xD;
5) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044b˝˝&#xD;
5) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044a˝˝&#xD;
6) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044d˝˝&#xD;
7) {candidate.triggeringResult} = 'TO_BE_DETERMINED' and {candidate.targetSystemCode} = 'DATAMOVER' ˝˝0044g˝˝&#xD;
9) {candidate.triggeringResult} = 'TO_BE_DETERMINED' ˝˝0044i˝˝&#xD;
&lt;/for each {candidate}></documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Pools and systems slots collection" id="id-cc61a012f2aa40edb7db005c6625362c">
      <documentation>Description: collection of available and used slots per target system and target pool&#xD;
&#xD;
Technically:&#xD;
˝˝0050a˝˝&#xD;
˝˝0050b˝˝</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Datamover slots collection" id="id-7f84f73f65e14f19aad394da1eb18b05">
      <documentation>Description: Collection of available and used slots for datamover&#xD;
&#xD;
Technically&#xD;
&lt;sql>&#xD;
select dtp.target_pool_key dmPoolKey, upper(dtp.target_pool_code) dmPoolCode, tp.target_pool_key tenantPoolKey, upper(tp.target_pool_code) tenantPoolCode, sum(ev.slots_needed) dmNeeded, sum(sign(coalesce(rn.rt_nodestatus_key, 0)) * ev.slots_needed) dmUsed&#xD;
  from dt_event ev &#xD;
  join dt_tenant t on upper(t.identifier) = upper(right(ev.uac_workflow_name, 3))&#xD;
  join dt_target_pool dtp on dtp.target_pool_key = ev.target_pool_key &#xD;
  join dt_target_system dts on dts.target_system_key = dtp.target_system_key &#xD;
  join dt_target_pool tp on upper(tp.target_pool_code) = upper(right(ev.uac_workflow_name, 3))&#xD;
  left join rt_nodestatus rn on rn.dt_event_key = ev.dt_event_key and rn.node_status in  ('RUNG', 'RERE', 'RUPR', 'REQC', 'REQT')&#xD;
  where dts.target_system_code = 'DATAMOVER'&#xD;
  group by dtp.target_pool_key, tp.target_pool_key, tp.target_pool_code , dtp.target_pool_code &#xD;
&lt;/sql>&#xD;
selected dataset ˝˝0049˝˝&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Nodes groups slots collection" id="id-c5100e37a8484877817b20223f5bdffb">
      <documentation>Description: Collection of available and used slots for user defined groups of nodes sharing limited number of slots&#xD;
&#xD;
Technically:&#xD;
˝˝0051a˝˝&#xD;
˝˝0051b˝˝</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Locked target objects collection" id="id-0ef30af303784f2f8e008c23204df689">
      <documentation>Description: Collection of target objects linked to processes in-progress&#xD;
&#xD;
Technically:&#xD;
select {lockedObjects} like&#xD;
&lt;sql>&#xD;
select&#xD;
  td.object_qualifier as objName,&#xD;
  max(td.usage_type) as usageType,&#xD;
  rn.target_pool_key,&#xD;
  case when rn.transformation_id = 9000000000000000002 then 1 else 0 end as backupBlocker&#xD;
from pu7_orchestration.v_running_nodes rn&#xD;
left join dt_transformation_object td&#xD;
  on td.dt_event_key = rn.dt_event_key&#xD;
group by td.object_qualifier, rn.target_pool_key, case when rn.transformation_id = 9000000000000000002 then 1 else 0 end&#xD;
&lt;/sql>&#xD;
&#xD;
˝˝0053b˝˝ all {lockedObjects}</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Potentialy needed target objects collection" id="id-65e89b70c5b94492bfb6c69eff65805a">
      <documentation>Description: The function collects target objects linked to triggering candidates&#xD;
&#xD;
Technically:&#xD;
&lt;sql>&#xD;
select distinct q.dt_event_key as nodeKey, o.object_qualifier as objName, o.usage_type as usageType&#xD;
from rt_event_request_queue q&#xD;
join dt_transformation_object o on o.dt_event_key = q.dt_event_key&#xD;
&lt;/sql>&#xD;
&#xD;
˝˝0055b˝˝</documentation>
    </element>
