    <element xsi:type="archimate:AccessRelationship" name="˝˝0041˝˝" id="id-1c4e6f7759724d9b8819ea930a10ab55" source="id-d418a9bfb3304b5991ddf1c078f32c60" target="id-b53c4e6569524831ba121613fd7c2b0f" accessType="1">
      <documentation>where {triggerFolderException.pattern} =  {candidate.uacWorkflowName}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0040˝˝" id="id-6f434ccd13664e3897376591fe4662f1" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-d418a9bfb3304b5991ddf1c078f32c60" target="id-55acd5ccca904cdcb83941cc263d866c" accessType="1">
      <documentation>SELECT TRIM(elem) AS pattern&#xD;
FROM ot_dynamic_property,&#xD;
     unnest(string_to_array(property_value, ',')) AS elem&#xD;
WHERE property_name = 'batch.server.exception'&#xD;
  AND TRIM(elem) &lt;> '';&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0036˝˝" id="id-b6e35b2171a34c17a7426b35bd41dd6e" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-d418a9bfb3304b5991ddf1c078f32c60" target="id-0eeef27b5abe4866b8c5d27540001bd8" accessType="1">
      <documentation>&lt;sellist>case when lnd.sandbox_code ='' then 'SBXDEFAULT' else lnd.sandbox_code end || '_' || lnd.full_file_name || '_' || @trfId || '_' || to_char(@triggerCandid.business_date, 'YYYYMMDD') || '_' || coalesce(@occ2trigger,1) || '.trigger' as triggerFileName&lt;/sellist>&#xD;
where rt_landing_key = {landKey}</documentation>
    </element>
    <element xsi:type="archimate:AssociationRelationship" id="id-c4887319189f442aabd58c9fcfe2bdda" source="id-ed175a6bd4794d22ac2439f7d04691d8" target="id-55eb70397216417f9ff9a072e011ec3c"/>
