    <element xsi:type="archimate:ApplicationFunction" name="Delete Filter" id="id-92687ff9873b4b2592455a487e86de11">
      <documentation>Description: This function removes materialized filter, filter detail and filter definition

Technically:
1)
&lt;sql>
DELETE FROM ot_custom_filter_members
WHERE filter_key = {filterKey}
&lt;/sql>

2)
&lt;sql>
DELETE FROM ot_custom_filter_fav
WHERE filter_key = {filterKey}
&lt;/sql>

3)
&lt;sql>
DELETE FROM ot_custom_filter_detail
WHERE filter_key = {filterKey}
&lt;/sql>

4)
&lt;sql>
DELETE FROM ot_custom_filter
WHERE filter_key = {filterKey}
&lt;/sql>
</documentation>
    </element>
