    <element xsi:type="archimate:ApplicationFunction" name="unlinkFeatureFromFilter" id="id-627626f2ff4f4a798f249fc4874d1dfe">
      <documentation>Description: removes link between filter and feature

Technically:
&lt;sql>
UPDATE dt_filter_feature_full
SET deleted_flag = 1, valid_to = current_timestamp, updated_by = user, updated_datetime = current_timestamp
WHERE
filter_key = {filterKey}
&lt;if {featureKey} is not null>
AND feature_key = {featureKey}
&lt;/if>
&lt;/sql></documentation>
    </element>
