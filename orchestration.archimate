</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Backup candidate" id="id-55c089bc8623402f841eec261c187c4d"/>
    <element xsi:type="archimate:ApplicationFunction" name="Erase another instance of the same execution from planning" id="id-dbfe954cddfe474b8a0e4917c19826fa"/>
    <element xsi:type="archimate:ApplicationFunction" name="Determine trigger filename" id="id-3370e6c5112a4b019cd97625f2c0d5d5">
      <documentation>Description: The function determines trigger file name&#xD;
&#xD;
Technically&#xD;
&lt;if {candidate.requested_by} starts with string 'LANDING' >&#xD;
parse {landKey} from {candidate.requested_by} like a string between curle brackets &quot;{}&quot;&#xD;
{triggerFileName} := ˝˝0036˝˝&#xD;
&lt;/if {candidate.requested_by} starts with string 'LANDING' >&#xD;
&#xD;
&lt;if {candidate.requested_by} doesn't start with string 'LANDING' >&#xD;
˝˝0037˝˝ as {maxOccurrence}&#xD;
{triggerFileName} = {candidate.uacWorkflowName} || '_' || {candidate.transformation_id} || '_' || FORMAT({candidate.businessDate}, 'YYYYMMDD') || '_' || coalesce({maxOccurrence},1) || '.trigger'&#xD;
&lt;/if {candidate.requested_by} doesn't start with string 'LANDING' >&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Node" id="id-7f247d8438a54d529b2ebe92422aa0ae"/>
    <element xsi:type="archimate:ApplicationService" name="Create execution candidate" id="id-64a13a01be4742bba0a1fcd28d6fdafa">
