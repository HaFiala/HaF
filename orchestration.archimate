    <element xsi:type="archimate:ApplicationFunction" name="Execution candidates selection" id="id-515858d9c3ba455691935e9b1f60bbf0">
      <documentation>Description: select candite nodes from queue with order by priority. One record is named like &quot;candidate&quot;&#xD;
&#xD;
Technically:&#xD;
&lt;sql>&#xD;
with q as (SELECT --distinct -- proč je tady distinct?&#xD;
		  rt_event_request_key AS eventRequestKey&#xD;
		, request_created_datetime AS requestCreatedTime&#xD;
		, dt_event_key AS eventDefinitionKey&#xD;
		, business_date AS businessDate&#xD;
		, data_version_number AS {dataVersionNo}&#xD;
		, occurrence&#xD;
        , coalesce(request_context ->> 'priority', 'STANDARD') as priorityCode&#xD;
		, file_trigger_name as fileTriggerName&#xD;
		, requested_by as requestedBy&#xD;
		, inserted_datetime&#xD;
	FROM rt_event_request_queue&#xD;
)&#xD;
, prio as (SELECT vnp.dt_event_key, MIN(vnp.feature_value) AS feature_value FROM q join v_node_priority vnp on vnp.dt_event_key = q.eventDefinitionKey group by vnp.dt_event_key)&#xD;
SELECT --distinct -- proč je tady distinct?&#xD;
		  q.eventRequestKey&#xD;
		, q.requestCreatedTime&#xD;
		, q.eventDefinitionKey&#xD;
		, q.businessDate&#xD;
		, q.dataVersionNo&#xD;
		, q.occurrence&#xD;
  		, ev.dt_tenant_key AS tenantKey&#xD;
		, ev.uac_workflow_name AS uacWorkflowName&#xD;
		, ev.transformation_id AS transformationId&#xD;
		, prio.feature_value&#xD;
		, coalesce(prio.feature_value,q.priorityCode) as priorityCode&#xD;
		, ev.node_type AS nodeType&#xD;
		, tn.Identifier AS tenantCode&#xD;
		, q.fileTriggerName&#xD;
		, q.requestedBy&#xD;
		, ev.data_mover_flag as dataMoverFlag&#xD;
		, ev.job_type&#xD;
 		, case when prio.feature_value = 'EXCLUSIVE' then 0&#xD;
		       when q.priorityCode = 'FORCE_HIGH' then 1&#xD;
			   else 2 &#xD;
		  end as context_order&#xD;
		, case when precedence.next_business_day is not null then 0 else 1 end as prec_order&#xD;
		, dtp.target_system_key targetSystemKey&#xD;
		, dtp.target_pool_key&#xD;
		, ev.slots_needed slotsNeeded&#xD;
		, dts.target_system_code targetSystemCode&#xD;
		, q.inserted_datetime&#xD;
		, dtp.starvation_min&#xD;
        , 'NOT_CHECKED' as triggeringResult&#xD;
        , cast(NULL as varchar(2000) postponeReason&#xD;
      , upper(right(ev.uac_workflow_name, 3)) dmTenant&#xD;
, upper(tn.target_trigger_folder) as defaultTriggerFolder&#xD;
, upper(ev.target_layer) as targetLayer&#xD;
	FROM q&#xD;
	join dt_event ev on ev.dt_event_key = q.eventDefinitionKey&#xD;
	join dt_tenant tn on tn.dt_tenant_key = ev.dt_tenant_key&#xD;
	LEFT JOIN prio on prio.dt_event_key = q.eventDefinitionKey&#xD;
-- this part regarding precedence must be re-designed. At the moment it doesn't work properly	&#xD;
LEFT JOIN rt_priority_schedule_active precedence ON precedence.priority_type = 'PRECEDENCE' AND q.businessDate = precedence.next_business_day AND tn.identifier = precedence.precedence_tenant&#xD;
	join dt_target_pool dtp on dtp.target_pool_key = ev.target_pool_key&#xD;
	join dt_target_system dts on dts.target_system_key = dtp.target_system_key&#xD;
	order by context_order, prec_order, priorityCode, q.requestCreatedTime&#xD;
&lt;/sql>&#xD;
&#xD;
˝˝0052b˝˝ all selected records</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Generate trigger request" id="id-d418a9bfb3304b5991ddf1c078f32c60">
      <documentation>Description: The function creates physical trigger file in proper folder and moves request from candidate to triggered&#xD;
&#xD;
Technically:&#xD;
1)&#xD;
&lt;Trigger file name determination>&#xD;
&lt;if {candidate.requested_by} starts with string 'LANDING' >&#xD;
parse {landKey} from {candidate.requested_by} like a string between curle brackets &quot;{}&quot;&#xD;
{triggerFileName} := ˝˝0036˝˝&#xD;
&lt;/if {candidate.requested_by} starts with string 'LANDING' >&#xD;
&#xD;
&lt;if {candidate.requested_by} doesn't start with string 'LANDING' >&#xD;
{triggerFileName} = {candidate.uacWorkflowName} || '_' || {candidate.transformation_id} || '_' || FORMAT({candidate.businessDate}, 'YYYYMMDD') || '_' || {occ2Trigger} || '.trigger'&#xD;
&lt;/if {candidate.requested_by} doesn't start with string 'LANDING' >&#xD;
&lt;/Trigger file name determination>&#xD;
&#xD;
2)&#xD;
&lt;Agent determination>&#xD;
NOTE: folder determination will be replaced by agent determination {agentURL}&#xD;
&lt;/Agent determination>&#xD;
&#xD;
&lt;Trigger folder determination>&#xD;
{specific_trigger_folder} = empty&#xD;
&#xD;
˝˝0040a˝˝ result from ˝˝0040˝˝&#xD;
˝˝0041˝˝&#xD;
if record is found then {specific_trigger_folder} := ˝˝0042˝˝&#xD;
&#xD;
if {specific_trigger_folder} is empty then {triggerFileFolder} = {candidate.defaultTriggerFolder}&#xD;
if {specific_trigger_folder} is not empty then {triggerFileFolder} = {specific_trigger_folder}&#xD;
&lt;/Trigger folder determination>&#xD;
&#xD;
3) &#xD;
˝˝0059˝˝&#xD;
&lt;if response is OK (200)>&#xD;
˝˝0059a˝˝&#xD;
&lt;/if response is OK (200)>&#xD;
&#xD;
&lt;if response is NOK>&#xD;
˝˝0059b˝˝&#xD;
&lt;/if response is NOK>&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Update registers" id="id-9739832be1b54ea0b76c173931c70c1a">
      <documentation>Description: the function updates all registers in order to have correct values for next candidate. It is last step of checking trigerring candidate&#xD;
&#xD;
Technically&#xD;
