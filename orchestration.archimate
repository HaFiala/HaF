    <element xsi:type="archimate:CompositionRelationship" id="id-602766c4ce8d472aa6c83a04cb11436b" source="id-706b594bfa174427b44a4d500a1f73be" target="id-40c473768525463690736e89e8e77b63"/>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0011˝˝" id="id-3d7a89dd1e7e487091d28aa2db7b027b" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-0fbdf6270966417199e3213d599af680" target="id-55eb70397216417f9ff9a072e011ec3c" accessType="1">
      <documentation>&lt;sellist>*&lt;/sellist>where transformation_id = 9000000000000000002</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0012˝˝" id="id-f6408bcaea2540b5baf19de3eb7d84f5" source="id-0fbdf6270966417199e3213d599af680" target="id-d17ff63dffa04c57a77391185c479d6a">
      <documentation>the result of select</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0013˝˝" id="id-eba0ae42473d4e4ab1bd784393201628" source="id-528e2658544d40b8ab8223c7738843bf" target="id-d17ff63dffa04c57a77391185c479d6a" accessType="1">
      <documentation>where {runningBackups.tenant_code} = {candidate.dmTenant}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0014˝˝" id="id-cae9f83b417342cc99ab14577db3eed0" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-528e2658544d40b8ab8223c7738843bf" target="id-07ff9593385e4f67b3472451107093c1">
      <documentation>{candidate.triggeringResult} = 'POSTPONE' and {candidate.postponeReason} =  'BACKUP_ON_TENANT_IN_PROGRESS' </documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0016˝˝" id="id-b3d1a00a10d847f3845067baceb26863" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-adb855c2abad408cad358bf888def9b6" target="id-07ff9593385e4f67b3472451107093c1">
      <documentation> {candidate.triggeringResult} = 'POSTPONE' and {candidate.postponeReason} =  'BACKUP_ON_ANOTHER_TENANT_IN_PROGRESS' and leave the check</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0015˝˝" id="id-145e18ce63d5442c87ff73f6f0a1b194" source="id-adb855c2abad408cad358bf888def9b6" target="id-d17ff63dffa04c57a77391185c479d6a" accessType="1">
      <documentation>where {runningBackups.tenant_code} = {candidate.dmTenant} like {backupBlockerNode}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0017˝˝" id="id-b89bd832aab447568eb5ce938c05afba" source="id-adb855c2abad408cad358bf888def9b6" target="id-d17ff63dffa04c57a77391185c479d6a" accessType="1">
      <documentation>first record like {bckInProgress}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0018˝˝" id="id-24425b6abb604b85a4d1a60f74d04650" source="id-adb855c2abad408cad358bf888def9b6" target="id-d17ff63dffa04c57a77391185c479d6a">
      <documentation>if {bckInProgress} found then : {tenant_code} = {candidate.dmTenant}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0019˝˝" id="id-ac155652b0974acfb809958250073736" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-adb855c2abad408cad358bf888def9b6" target="id-8979ec7ad45c42f8b5a711b5d12659af" accessType="1">
      <documentation>&lt;sellist>distinct dt_event_key as nodeKey, object_qualifier as objName, usage_type as usageType&lt;/selList> where dt_event_key = {backupBlockerNode.dt_event_key} like {blockedObjects}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0020˝˝" id="id-133cbce68b674e0ab9b13edcf6604687" source="id-adb855c2abad408cad358bf888def9b6" target="id-7e0b69c689d64e3b9beb5420833603ee">
      <documentation>all records selected in previous step, like a target_pool_key use {backupBlockerNode.target_pool_key} for backupBlocker use 1.</documentation>
    </element>
    <element xsi:type="archimate:ServingRelationship" name="˝˝0021˝˝" id="id-742b4ec87d584c5994d7ad4f3139d0d3" source="id-33c114ccc522409bb00fa9a42f12e4fe" target="id-adb855c2abad408cad358bf888def9b6">
      <documentation>passing parameters nodeKey = {backupBlockerNode.dt_event_key}, businessDate = cast(current_timestamp as date), status = 'RUNG', transformationRunID = 'BACKUP' || '-' || {candidate.dmTenant} || '-' || 9000000000000000002 || '-' || current_timestamp, user = 'BACKUP:' || {candidate.eventRequestKey}</documentation>
    </element>
    <element xsi:type="archimate:AssociationRelationship" id="id-4cf37981b09d464ea01ef9ab78c137e3" source="id-688570bd0f864baf83b306c8922d47f3" target="id-e637cdd2931c4cf18eee50212c149df0"/>
    <element xsi:type="archimate:AccessRelationship" id="id-0941fcbba41d40bb9fb1b5e41e586b6b" source="id-33c114ccc522409bb00fa9a42f12e4fe" target="id-e09bd8262d3b40b49e6ed0436dea2616"/>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0022˝˝" id="id-285f62ab99dc408ab344ad02e230e68c" source="id-688570bd0f864baf83b306c8922d47f3" target="id-7e0b69c689d64e3b9beb5420833603ee" accessType="1">
      <documentation>where backupBlocker = 0 and target_pool_key = {backupBlockerNode.target_pool_key}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0023˝˝" id="id-456990984ba744fd91f3ca7359a86af0" source="id-688570bd0f864baf83b306c8922d47f3" target="id-d17ff63dffa04c57a77391185c479d6a" accessType="1">
      <documentation>where tenant_code = {candidate.dmTenant}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0024˝˝" id="id-b2231363a59f45028f6233049acf7f71" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-688570bd0f864baf83b306c8922d47f3" target="id-07ff9593385e4f67b3472451107093c1">
      <documentation>{candidate.triggeringResult} = 'POSTPONE' and {candidate.postponeReason} =  'BACKUP_POSTPONED_DUE_TO:' &amp; {runNode.objName}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0025˝˝" id="id-3c8134e94f2046de8c7a1417080f055e" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-688570bd0f864baf83b306c8922d47f3" target="id-52486797dd7343aca178f628a33311ed" accessType="1">
      <documentation>&lt;list>requestCreatedTime + cast((non_starting_period || ' minutes') as interval) as ntpEnd &lt;/list> &#xD;
where upper(identifier) = upper({candidate.dmTenant})</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0026˝˝" id="id-e3999ce407414b89845189c13c76dde3" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-acc6d99d79da4e6fb37b299223043501">
      <documentation>set resUsed = resUsed + {candidate.slotsNeeded}, resAvailable = resAvailable - {candidate.slotsNeeded}&#xD;
where target_system_key = {candidate.target_system_key} and targetPoolKey = -1</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0027˝˝" id="id-44d7aad2429a4f80b4bcd03f70de605a" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-acc6d99d79da4e6fb37b299223043501">
      <documentation>set resUsed = resUsed + {candidate.slotsNeeded}, resAvailable = resAvailable - {candidate.slotsNeeded}&#xD;
where target_pool_key = {candidate.target_pool_key}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0028˝˝" id="id-cd204914e930417bb428036fb2e7bedf" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-cc8fda20ffa34422940cf0fb77b2b3ee">
      <documentation>set dmUsed = dmUsed + {candidate.slotsNeeded} where {tenantPoolCode} = {candidate.dmTenant}&#xD;
&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0031˝˝" id="id-db6bd90c1052434184ed095f15558d52" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-1ea76a953f2a485ebc6952641ad17397">
      <documentation>set resused = resused + {candidate.slotsNeeded}, resavailable = resavailable - {candidate.slotsNeeded} where {[register] groupSlots.filterkey} = {nodesFilters.filterkey}&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0030˝˝" id="id-da4b891bae1b4f6e910f2d0d998f0f3b" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-45b7cd81a8e242fa90bd585931e7482b" accessType="1">
      <documentation>where {candidatesGroups.eventDefinitionKey} = {candidate.dt_event_key} as {nodesFilters}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0033˝˝" id="id-77f281fa0a5c43dda77c4537137725c8" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-7e0b69c689d64e3b9beb5420833603ee">
      <documentation>objName = {needObject.objName}, usageType = {needObject.usageType}, target_pool_key = {candidate.target_pool_key}, backupBlocker = 0 if such record doesn't exist yet</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0032˝˝" id="id-d9d98edfab9c47bb99cefbde00942ebf" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-db45581e9b974dd9beeb5bc3f0a3797e" accessType="1">
      <documentation>where dt_event_key = {candidate.eventDefinitionKey} like {needObjects}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0034˝˝" id="id-09397b319ae64f8080f4d7032016cb16" profiles="id-a7e8820c56ae4568878dcac1a600f520" source="id-9739832be1b54ea0b76c173931c70c1a" target="id-07ff9593385e4f67b3472451107093c1">
      <documentation>{candidate.triggeringResult} = '2TRIGGER' </documentation>
    </element>
    <element xsi:type="archimate:ServingRelationship" name="˝˝0035˝˝" id="id-959dba6bc52c496aa1f3c7e2ea8f1cc3" source="id-4a2d40cc05db4c18a2829f9078106080" target="id-0d6f8be5c916439d8ca36e80f07d8f3d">
      <documentation>passing parameters: busDate= {candidate.business_date}, runIdPrefix='VIRTUAL-NODE', nodeKey = {candidate.dt_event_key}, occ = {occ2trigger}, dataVersion = {candidate.data_version_number}, tenantCode = {candidate.tenantCode}, transformationId = {candidate.transformationId}</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="˝˝0042˝˝" id="id-62b6fe8947ac408dac77cda1b4c4162b" profiles="id-72eec35c304140108ce8d98d82d6d7af" source="id-d418a9bfb3304b5991ddf1c078f32c60" target="id-aa0ea77e4102460bab19d3d3684e8303" accessType="1">
      <documentation>&lt;sellist>specific_trigger_folder&lt;/sellist>&#xD;
where UPPER(target_layer) = {candidate.targetLayer}</documentation>
    </element>
