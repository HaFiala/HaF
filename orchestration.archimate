    <element xsi:type="archimate:ApplicationProcess" name="Node Definition Processing" id="id-bf85d5a52c4149039ce9c052e949b5a4">
      <documentation>Description: processing of metadata definition - node definition&#xD;

Technically:
1) ˝˝0101a˝˝  and ˝˝0101b˝˝  include {errorMessage} as empty field
2)
&lt;For each {nodeRecord}>
˝˝0101c˝˝
	&lt;if {errorMessage} is empty>
	˝˝0101e˝˝
		if {nodeRecord.dbEventKey} empty ˝˝0101g˝˝ with parameters {nodeDefinition} = {nodeRecord} returning {nodeKey}
		if {nodeRecord.dbEventKey} not empty and (
				{transformationName} != {dbTransformationName} OR {uacWorkflowName} != {dbUacWorkflowName} OR {nodeType} != {dbNodeType} OR {targetLayer} != {dbTargetLayer} OR {sourceSystem} != {dbSourceSystem} OR {functionalArea} != {dbFunctionalArea} OR {dataVersion} != {dbDataVersion} OR {ddaCalendar} != {dbDdaCalendar} OR {ddaFrequency} != {dbDdaFrequency} OR {ddaFinishBy} != {dbDdaFinishBy} OR {dataVersionRelationType} != {dbDataVersionRelationType} OR {sandboxCode} != {dbSandboxCode} OR {blockUnnecessaryReprocessingLevel} != {dbBlockUnnecessaryReprocessingLevel} OR {nodeDeliveryType} != {dbNodeDeliveryType} OR {freezeAfterCutoff} != {dbFreezeAfterCutoff} OR {landingFlag} != {dbLandingFlag} OR {dataMoverFlag} != {dbDataMoverFlag} OR {jobType} != {dbJobType} OR {sourceFilename} != {dbSourceFilename} OR {d2dStgCopy} != {dbD2dStgCopy} OR {d2dStgCopyGroup} != {dbD2dStgCopyGroup} OR {responsibleTeam} != {dbResponsibleTeam} OR {targetPoolKey} != {dbTargetPoolKey} OR {slotsNeeded} != {dbSlotsNeeded} OR {definitionPriority} != {dbDefinitionPriority} ˝˝0101h˝˝ with parameters {nodeDefinition} = {nodeRecord} )
	&lt;if {errorMessage} is empty>
&lt;/></documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="validateNodeDefinition" id="id-ad513569371e4fd18ccc6cd99f9a0f76">
      <documentation>Description: Validation of node definition input whether it corresponds to defined business/orchestration rules&#xD;

&lt;sql>&#xD;
select coalesce (sum(case when e.landing_flag = 'YES' then 1 else 0 end), 0) landings&#xD;
     , coalesce (sum(case when e.landing_flag = 'YES' then 0 else 1 end), 0) nonlandings&#xD;
	from dt_event e&#xD;
	join dt_tenant t on t.dt_tenant_key = e.dt_tenant_key and upper(t.identifier) = upper({tenantCode}) &#xD;
	where upper(uac_workflow_name)  = upper({popular_name})&#xD;
	  and e.transformation_id &lt;> {transformationId}&#xD;
&lt;/sql>
&#xD;
if coalesce(:nodeRecord.landingNode, 'NO') = 'YES' and {landings} + {nonlandings} > 0 then {errorMessage} = 'NON UNIQUE POPULAR NAME FOR LANDING'&#xD;
if coalesce(:nodeRecord.landingNode, 'NO') = 'NO' and {landings} > 0 then {errorMessage} = 'COLISION WITH POPULAR NAME FOR LANDING' 

 ˝˝0101d˝˝&#xD;
&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="updateNodeDefinition" id="id-3c62d052787348c2b1e3b7489019e5be">
      <documentation>Description: update node definition in database

1) ˝˝0101i˝˝ with parameter {nodeKey} = {dbNodeKey} and {deletedFlag} = 0

2) ˝˝0101j˝˝ with parameters {nodeDefinition} = {nodeRecord} </documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="insertNodeDefinition" id="id-19a7e14db0d246d791d82b2adf715a2f">
      <documentation>Description: inserts node definition into database and gets dt_event_key of new node

Technically:
&lt;sql>
INSERT INTO dt_event
(dt_tenant_key, identifier, transformation_id, transformation_name, uac_workflow_name, node_type, target_layer, source_system, functional_area, deleted_flag, inserted_by, inserted_datetime, updated_by, updated_datetime, valid_to, data_version, dda_calendar, dda_frequency, dda_finish_by, data_version_relation_type, sandbox_code, block_unnecessary_reprocessing_level, node_delivery_type, freeze_after_cutoff, landing_flag, data_mover_flag, job_type, source_filename, d2d_stg_copy, d2d_stg_copy_group, responsible_team, target_pool_key, slots_needed, definition_priority)
VALUES( {tenantKey}, {transformationId}, {transformationId}, {transformationName}, {uacWorkflowName}, {nodeType}, {targetLayer}, {sourceSystem}, {functionalArea}, 0, user, current_datetime, user, current_datetime,'2299-12-31 12:00:00.000', {dataVersion}, {ddaCalendar}, {ddaFrequency}, {ddaFinishBy}, {dataVersionRelationType}, {sandboxCode}, {blockUnnecessaryReprocessingLevel}, {nodeDeliveryType}, {freezeAfterCutoff}, {landingFlag}, {dataMoverFlag}, {jobType}, {sourceFilename}, {d2dStgCopy}, {d2dStgCopyGroup}, {responsibleTeam}, {targetPoolKey}, {slotsNeeded}, {definitionPriority});
&lt;/sql></documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Authorization Service" id="id-397bf9803e0c4e729f7671aba5690e3d"/>
    <element xsi:type="archimate:ApplicationService" name="Export metadata definition" id="id-85dad1c5104a436cbeeb0fe1eba0ae54"/>
    <element xsi:type="archimate:ApplicationFunction" name="Candidates group membership selection" id="id-15943033c79a4f4596ab28e32f77bbc8">
      <documentation>Description: selection of user defined resources group for triggering candidates&#xD;
&#xD;
Technically&#xD;
&lt;sql>&#xD;
SELECT dff.filter_key as filterKey,&#xD;
    ocfm.dt_event_key as eventDefinitionKey&#xD;
    FROM rt_event_request_queue queue&#xD;
    join v_node_feature nf on queue.dt_event_key = nf.dt_event_key&#xD;
    where feature_type_code = 'RESOURCE'&#xD;
&lt;/sql>&#xD;
&#xD;
˝˝0054b˝˝</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Historize definition data" id="id-ab21fdb194064dbea4326e777aedce06">
      <documentation>The function creates new record in _history partition of definition table.&#xD;
All the columns are the same like historized record except of&#xD;
valid_to => it is set to current_timestamp&#xD;
deleted_flag => in case of delete it is set to 1&#xD;
updated_datetime => in case of delete it is set to current_timestamp&#xD;
updated_by => in case of delete it is set to current_user&#xD;
&#xD;
Each record is historized into table [original_table_name]_history&#xD;
A key value of record to be provided and key_column name&#xD;
&#xD;
For delete sets valid</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="[register] dbStructure" id="id-b8e64c7d72da4087b319a28968dc60b8">
      <documentation>The register contains list of tables and its columns within orchestration database.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Authorize for changes" id="id-f3324dd22c784c799ea0f86c9342806f"/>
    <element xsi:type="archimate:DataObject" name="[definition] popular name uniqueness" id="id-211471b992064327b2f52c865bdec826">
      <documentation>A node's popular name must be unique for every landing node.&#xD;
Reason: the technical node which is triggered for landing depends on the popular name, hence uniqueness is needed in order to be deterministic</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Link Definition Processing" id="id-7f341f156b3445b98afca21598f9f446">
      <documentation>Description: processing of metadata definition - part links between nodes

Technically:
1) ˝˝0100a˝˝   and  ˝˝0100g˝˝   as {linkRecord} include {fromNode}, {toNode}, {errorMessage}, {linkKey} as empty field
2) 
&lt;For each {linkRecord}>
	 ˝˝0100b˝˝  
	&lt;if {linkRecord.errorMessage} is empty> 
		&lt;if {linkRecord.toDelete} = true>
			 ˝˝0100d˝˝  with parameters {linkKey} = {linkRecord.linkKey} and deletedFlag = 1
		&lt;/if {linkRecord.toDelete} = true>  
		if {linkRecord.linkKey} is empty then ˝˝0100e˝˝  with parameters fromNodeKey = {fromNodeKey}, toNodeKey= {toNodeKey} and next {linkRecord}
		if {linkRecord.linkKey} not empty and ({ood}!={obligatoryOnDelivery} or {oor}!={obligatoryOnRelivery} or {tod}!={triggerOnDelivery} or {tor}!={triggerOnRelivery}) ˝˝0100f˝˝
	&lt;/if {linkRecord.errorMessage} is empty> 
	
</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="insertLinkDefinition" id="id-12fdb47ea2cf44d4a332b13bbdb212d6">
      <documentation>Description: The function creates dependency link between nodes.

Technically:
&lt;sql>
  INSERT INTO dt_event_link_full
        (dt_event_key_1,
        dt_event_key_2,
        dt_event_link_cond_type_key,
        dt_event_link_type_key,
        deleted_flag,
        inserted_by,
        inserted_datetime,
        updated_by,
        updated_datetime,
        obligatory_on_delivery,
        obligatory_on_redelivery,
        trigger_on_delivery,
        trigger_on_redelivery)
        VALUES (
        {fromNode},
        {toNode},
        -1,
        -1,
        0,
        {insertedBy},
        now(),
        {updatedBy},
        now(),
        coalesce({obligatoryOnDelivery}, 1),
        coalesce({obligatoryOnRedelivery}, 1),
        coalesce({triggerOnDelivery}, 1),
        coalesce({triggerOnRedelivery}, 1))
            RETURNING dt_event_link_key;
&lt;/sql></documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="updateLinkDefinition" id="id-a488f5cc0e58427da73516c387ea45d7">
      <documentation>Description: The function updates dependency link between nodes.

Technically:
˝˝0100j˝˝ with parameters linkKey = {linkRecord.linkKey} and deletedFlag = 0

&lt;sql>
  INSERT INTO dt_event_link_full
        (dt_event_link_key,
		dt_event_key_1,
        dt_event_key_2,
        dt_event_link_cond_type_key,
        dt_event_link_type_key,
        deleted_flag,
        inserted_by,
        inserted_datetime,
        updated_by,
        updated_datetime,
        obligatory_on_delivery,
        obligatory_on_redelivery,
        trigger_on_delivery,
        trigger_on_redelivery)
        VALUES (
		{linkKey}
        {fromNode},
        {toNode},
        -1,
        -1,
        0,
        {insertedBy},
        now(),
        {updatedBy},
        now(),
        coalesce({obligatoryOnDelivery}, 1),
        coalesce({obligatoryOnRedelivery}, 1),
        coalesce({triggerOnDelivery}, 1),
        coalesce({triggerOnRedelivery}, 1));
&lt;/sql></documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="historizeLinkDefinitionData" id="id-336833bc9d9e4f9996589ea8b8abd7e2">
      <documentation>Description: historize record of invalid link 

Technically:
&lt;sql>
UPDATE dt_event_link_full
SET deleted_flag = {deletedFlag},
updated_by = CASE WHEN {deletedFlag} = 1 THEN user ELSE updated_by END,
updated_datetime = CASE WHEN {deletedFlag} = 1 THEN current_timestamp ELSE updated_datetime END
valid_to = now()
where dt_event_link_key = {linkKey}
&lt;/sql></documentation>
    </element>
