    <element xsi:type="archimate:ApplicationFunction" name="historizeNodeDefinition" id="id-e15e20867e5146659b0f37e7e050c743">
      <documentation>Description: invalidates current node definition

Technically:
&lt;sql>
UPDATE dt_event_full
SET deleted_flag = {deleted_flag}, valid_to = current_timestamp
WHERE dt_event_key = {nodeKey}
&lt;/sql></documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="nodeSelection" id="id-040377254a574a20a4776756ea2e0c92">
      <documentation>Description: selects existing node from the database

Technically:
&lt;sql>
SELECT 
	dt_event_key as dbEventKey,
    transformation_name as dbTransformationName,
    uac_workflow_name as dbUacWorkflowName,
    node_type as dbNodeType,
    target_layer as dbTargetLayer,
    source_system as dbSourceSystem,
    functional_area as dbFunctionalArea,
    data_version as dbDataVersion,
    dda_calendar as dbDdaCalendar,
    dda_frequency as dbDdaFrequency,
    dda_finish_by as dbDdaFinishBy,
    data_version_relation_type as dbDataVersionRelationType,
    sandbox_code as dbSandboxCode,
    block_unnecessary_reprocessing_level as dbBlockUnnecessaryReprocessingLevel,
    node_delivery_type as dbNodeDeliveryType,
    freeze_after_cutoff as dbFreezeAfterCutoff,
    landing_flag as dbLandingFlag,
    data_mover_flag as dbDataMoverFlag,
    job_type as dbJobType,
    source_filename as dbSourceFilename,
    d2d_stg_copy as dbD2dStgCopy,
    d2d_stg_copy_group as dbD2dStgCopyGroup,
    responsible_team as dbResponsibleTeam,
    target_pool_key as dbTargetPoolKey,
    slots_needed as dbSlotsNeeded,
    definition_priority as dbDefinitionPriority
FROM dt_event d
JOIN dt_tenant t 
    ON d.dt_tenant_key = t.dt_tenant_key 
WHERE transformation_id = {nodeRecord.transformationId}
  AND t.identifier = UPPER({nodeRecord.tenantCode});
&lt;/sql>

if {dbEventKey} not empty ˝˝0101f˝˝</documentation>
    </element>
