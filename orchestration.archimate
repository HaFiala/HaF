    <element xsi:type="archimate:ApplicationFunction" name="Check resources" id="id-d91e73bdfd614da68a5d259c85c7266f">
      <documentation>Corresponds to Target Slots Available? https://aconfluence.kbc.be:6081/confluence/spaces/BICC/pages/367928928/%C2%ABProcess%C2%BBtriggerCandidates#id-%C2%ABProcess%C2%BBtriggerCandidates-targetslotsavailable%3F</documentation>
