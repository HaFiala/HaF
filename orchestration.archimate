    <folder name="Data objects" id="id-80934ddddb8b4f029d9dc3dcae45dd16">
      <folder name="Tables &amp; views" id="id-36e5ade366af4a75b50469853b262547">
        <element xsi:type="archimate:DataObject" name="[table] dt_event" id="id-e32784341d2c425facbff824e7bdc513"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_feature" id="id-286793fbd929494fbdd328ab2503fcd3"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_feature_type" id="id-84a883fd8fa649d5b9645cc6ef554ec9"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_target_pool" id="id-db3661fd1d12462eb98245add687dc2b"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_target_system" id="id-04741f3b53c14b7f9b0d9579265fbbd2"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_tenant" id="id-52486797dd7343aca178f628a33311ed"/>
        <element xsi:type="archimate:DataObject" name="[table] rt_event_request_queue" id="id-b81f8bb476fd4f659e9e216c6e0b2840">
          <documentation>A partition of rt_event_request_full table. The partition contains requests in status REQQ (planned but not started yet)</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[table] rt_nodestatus" id="id-ed175a6bd4794d22ac2439f7d04691d8"/>
        <element xsi:type="archimate:DataObject" name="[table] rt_priority_schedule_active" id="id-359206b76e3a438dbda9e7cb1d3f5c3e"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_filter_feature" id="id-1ec1a8196e8e4e7889cce5fa187a135e"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_transformation_object" id="id-8979ec7ad45c42f8b5a711b5d12659af"/>
        <element xsi:type="archimate:DataObject" name="[table] ot_custom_filter_members" id="id-0be8c38dba41439dbccdd58c6fb650a0"/>
        <element xsi:type="archimate:DataObject" name="[table] ot_custom_filter" id="id-794aa182e272423984349cf5226fdf1d"/>
        <element xsi:type="archimate:DataObject" name="[view] v_node_feature" id="id-648deffb84944f1faa428f427fb2b052">
          <documentation>SELECT ocfm.dt_event_key,&#xD;
    ocf.filter_key,&#xD;
    ocf.filter_name,&#xD;
    fea.feature_value,&#xD;
    ft.feature_type_code,&#xD;
    ft.feature_type_desc&#xD;
   FROM ot_custom_filter_members ocfm&#xD;
     JOIN ot_custom_filter ocf ON ocf.filter_key = ocfm.filter_key&#xD;
     JOIN dt_filter_feature dff ON dff.filter_key = ocf.filter_key AND dff.valid_to > now()&#xD;
     JOIN dt_feature fea ON fea.dt_feature_key = dff.dt_feature_key&#xD;
     JOIN dt_feature_type ft ON fea.dt_feature_type_key = ft.dt_feature_type_key;</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[view] v_node_priority" id="id-c45082410d1347d5b8151763da898a8e">
          <documentation>SELECT ocfm.dt_event_key,&#xD;
    ocf.filter_key,&#xD;
    ocf.filter_name,&#xD;
    fea.feature_value,&#xD;
    ft.feature_type_code,&#xD;
    ft.feature_type_desc&#xD;
   FROM ot_custom_filter_members ocfm&#xD;
     JOIN ot_custom_filter ocf ON ocf.filter_key = ocfm.filter_key&#xD;
     JOIN dt_filter_feature dff ON dff.filter_key = ocf.filter_key&#xD;
     JOIN dt_feature fea ON fea.dt_feature_key = dff.dt_feature_key AND dff.valid_to > now()&#xD;
     JOIN dt_feature_type ft ON fea.dt_feature_type_key = ft.dt_feature_type_key&#xD;
  WHERE ft.feature_type_code::text = 'PRIORITY'::text;</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[view] v_running_nodes" id="id-55eb70397216417f9ff9a072e011ec3c">
          <documentation>SELECT e.dt_event_key,&#xD;
    e.dt_tenant_key,&#xD;
    e.transformation_id,&#xD;
    e.transformation_name,&#xD;
    e.uac_workflow_name,&#xD;
    e.node_type,&#xD;
    e.target_layer,&#xD;
    e.source_system,&#xD;
    e.functional_area,&#xD;
    e.data_version,&#xD;
    e.data_version_relation_type,&#xD;
    e.block_unnecessary_reprocessing_level,&#xD;
    e.node_delivery_type,&#xD;
    e.landing_flag,&#xD;
    e.data_mover_flag,&#xD;
    e.job_type,&#xD;
    e.target_pool_key,&#xD;
    e.slots_needed,&#xD;
    e.definition_priority,&#xD;
    s.node_status,&#xD;
    s.business_date,&#xD;
    s.data_version_number,&#xD;
    s.execution_context,&#xD;
    s.occurrence,&#xD;
    s.rt_event_key,&#xD;
    s.rt_event_request_key,&#xD;
    s.status_datetime,&#xD;
    s.target_pool_gen,&#xD;
    upper(t.identifier) tenant_code&#xD;
   FROM dt_event e&#xD;
   join dt_tenant t on t.dt_tenant_key = e.dt_tenant_key&#xD;
   JOIN rt_nodestatus s ON s.dt_event_key = e.dt_event_key AND (s.node_status::text = ANY (ARRAY['RUNG'::character varying, 'RERE'::character varying, 'RUPR'::character varying, 'REQT'::character varying, 'REQC'::character varying]::text[]))&#xD;
   ;</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[table] dt_target_pool_history" id="id-6c485055b0944f6991148557ecf61a40"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_target_system_history" id="id-4f299c7c333c4c788c4cb00d3b8886ea"/>
        <element xsi:type="archimate:DataObject" name="[table] rt_event_request" id="id-29d4d7d1b9a44a838a4981ff7cc6a3f4">
          <documentation>A partition of rt_event_request_full table. The partition contains requests in status REQQ (planned but not started yet)</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[view] v_target_slots_usage" id="id-96e1d90d83a641b689744bbb9406d71e">
          <documentation>WITH p AS (&#xD;
         SELECT COALESCE((rr.request_context -> 'targetPool'::text)::integer::bigint, de.target_pool_key) AS target_pool_key,&#xD;
            sum(&#xD;
                CASE&#xD;
                    WHEN a.node_status::text &lt;> 'REQQ'::text THEN de.slots_needed::integer&#xD;
                    ELSE 0&#xD;
                END) AS running,&#xD;
            sum(&#xD;
                CASE&#xD;
                    WHEN a.node_status::text = 'REQQ'::text THEN de.slots_needed::integer&#xD;
                    ELSE 0&#xD;
                END) AS queued&#xD;
           FROM rt_nodestatus a&#xD;
             JOIN dt_event de ON de.dt_event_key = a.dt_event_key&#xD;
             LEFT JOIN rt_event_request rr ON rr.rt_event_request_key = a.rt_event_request_key&#xD;
          WHERE a.node_status::text = ANY (ARRAY['RUNG'::character varying::text, 'RERE'::character varying::text, 'RUPR'::character varying::text, 'REQT'::character varying::text, 'REQC'::character varying::text, 'REQQ'::character varying::text])&#xD;
          GROUP BY (COALESCE((rr.request_context -> 'targetPool'::text)::integer::bigint, de.target_pool_key))&#xD;
        ), a AS (&#xD;
         SELECT dts.target_system_code,&#xD;
            dts.target_system_slots,&#xD;
            dts.target_system_key,&#xD;
            dtp.target_pool_key,&#xD;
            dtp.target_pool_code,&#xD;
            dtp.slots,&#xD;
            COALESCE(p.running, 0::bigint) AS running,&#xD;
            COALESCE(p.queued, 0::bigint) AS queued,&#xD;
            dtp.consecutive_fails_allowed&#xD;
           FROM dt_target_pool dtp&#xD;
             LEFT JOIN p ON p.target_pool_key = dtp.target_pool_key&#xD;
             JOIN dt_target_system dts ON dts.target_system_key = dtp.target_system_key&#xD;
        ), b AS (&#xD;
         SELECT a.target_system_code,&#xD;
            a.target_system_slots,&#xD;
            a.target_system_key,&#xD;
            NULL::bigint AS target_pool_key,&#xD;
            ((a.target_system_code::text || ' - ALL'::text))::character varying(1000) AS target_pool_code,&#xD;
            NULL::smallint AS slots,&#xD;
            sum(a.running) AS running,&#xD;
            sum(a.queued) AS queued&#xD;
           FROM a&#xD;
          GROUP BY a.target_system_code, a.target_system_slots, a.target_system_key&#xD;
        ), ph AS (&#xD;
         SELECT htp.target_pool_key,&#xD;
            htp.slots,&#xD;
            rank() OVER (PARTITION BY htp.target_pool_key ORDER BY htp.updated_datetime DESC) AS poradi&#xD;
           FROM dt_target_pool_history htp&#xD;
        ), sh AS (&#xD;
         SELECT dtsh.target_system_slots,&#xD;
            dtsh.target_system_key,&#xD;
            rank() OVER (PARTITION BY dtsh.target_system_key ORDER BY dtsh.updated_datetime DESC) AS poradi&#xD;
           FROM dt_target_system_history dtsh&#xD;
        )&#xD;
 SELECT a.target_system_code,&#xD;
    a.target_pool_code,&#xD;
    a.slots AS total,&#xD;
    a.slots - a.running AS available,&#xD;
    a.running,&#xD;
    a.queued,&#xD;
    a.target_system_slots,&#xD;
    a.target_system_key,&#xD;
    a.target_pool_key,&#xD;
    COALESCE(ph.slots, a.slots) AS prevslots,&#xD;
    a.consecutive_fails_allowed AS consecutivefailsallowed&#xD;
   FROM a&#xD;
     LEFT JOIN ph ON ph.target_pool_key = a.target_pool_key AND ph.poradi = 1&#xD;
UNION ALL&#xD;
 SELECT b.target_system_code,&#xD;
    b.target_pool_code,&#xD;
    b.target_system_slots AS total,&#xD;
    b.target_system_slots::numeric - b.running AS available,&#xD;
    b.running,&#xD;
    b.queued,&#xD;
    b.slots AS target_system_slots,&#xD;
    b.target_system_key,&#xD;
    b.target_pool_key,&#xD;
    COALESCE(sh.target_system_slots, b.target_system_slots) AS prevslots,&#xD;
    NULL::integer AS consecutivefailsallowed&#xD;
   FROM b&#xD;
     LEFT JOIN sh ON sh.target_system_key = b.target_system_key AND sh.poradi = 1;</documentation>
        </element>
        <element xsi:type="archimate:DataObject" name="[table] dt_event_history" id="id-679840e4d6584940a939723012ff07e7"/>
        <element xsi:type="archimate:DataObject" name="[table] dt_event_link" id="id-f913e392a7074694a3168b74d81d34e6"/>
